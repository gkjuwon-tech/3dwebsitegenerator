# ── Scene Compiler (always needed) ──
# The compiler authors sky/lighting/camera/models per brief via Claude.
ANTHROPIC_API_KEY=sk-ant-...
HERO_COMPILER_MODEL=claude-opus-4-8

# ── Generation pipeline (GPU host) ──
HERO_DEVICE=cuda
HERO_OUTPUT_DIR=./_packages
HERO_PUBLIC_BASE=/assets

# Model repos (override to pin versions / mirrors)
HERO_T2I_MODEL=stabilityai/stable-diffusion-xl-base-1.0
HERO_T2I_REFINER=stabilityai/stable-diffusion-xl-refiner-1.0
HERO_CONTROLNET_DEPTH=diffusers/controlnet-depth-sdxl-1.0
HERO_IP_ADAPTER=h94/IP-Adapter
HERO_DEPTH_MODEL=depth-anything/Depth-Anything-V2-Base-hf
HERO_TRIPOSR_MODEL=stabilityai/TripoSR

# InstantMesh final pass: point at a local clone with weights present
# HERO_INSTANTMESH_DIR=/opt/InstantMesh

# Optional gltfpack binary for Draco/meshopt/KTX2 compression
HERO_GLTFPACK=gltfpack
